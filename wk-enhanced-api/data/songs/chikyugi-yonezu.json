    { "jp": "<ruby>光<rt>ひかり</rt></ruby>さす<ruby>夢<rt>ゆめ</rt></ruby>を<ruby>見<rt>み</rt></ruby>る いつの<ruby>日<rt>ひ</rt></ruby>も", "en": "I dream a dream where light shines through, on any given day", "tokens": [ { "surface": "光", "lemma": "光", "reading": "ひかり", "pos": "NOUN", "jlpt": "N4", "gloss": "light" }, { "surface": "さす", "lemma": "さす", "reading": "さす", "pos": "VERB", "jlpt": "N2", "gloss": "to shine in (light)" }, { "surface": "夢", "lemma": "夢", "reading": "ゆめ", "pos": "NOUN", "jlpt": "N4", "gloss": "dream" }, { "surface": "見る", "lemma": "見る", "reading": "みる", "pos": "VERB", "jlpt": "N5", "gloss": "to see; have (a dream)" }, { "surface": "日", "lemma": "日", "reading": "ひ", "pos": "NOUN", "jlpt": "N5", "gloss": "day" } ] },
    { "jp": "<ruby>扉<rt>とびら</rt></ruby>を<ruby>今<rt>いま</rt></ruby><ruby>開<rt>あ</rt></ruby>け<ruby>放<rt>はな</rt></ruby>つ <ruby>秘密<rt>ひみつ</rt></ruby>を<ruby>暴<rt>あば</rt></ruby>くように", "en": "Now I throw the door wide open, as if to uncover a secret", "grammar": ["you-da"], "tokens": [ { "surface": "扉", "lemma": "扉", "reading": "とびら", "pos": "NOUN", "jlpt": "N2", "gloss": "door" }, { "surface": "今", "lemma": "今", "reading": "いま", "pos": "NOUN", "jlpt": "N5", "gloss": "now" }, { "surface": "開け放つ", "lemma": "開け放つ", "reading": "あけはなつ", "pos": "VERB", "jlpt": "N1", "gloss": "to throw open; fling open" }, { "surface": "秘密", "lemma": "秘密", "reading": "ひみつ", "pos": "NOUN", "jlpt": "N3", "gloss": "secret" }, { "surface": "暴く", "lemma": "暴く", "reading": "あばく", "pos": "VERB", "jlpt": "N1", "gloss": "to expose; uncover" } ] },
    { "jp": "<ruby>手<rt>て</rt></ruby>が<ruby>触<rt>ふ</rt></ruby>れ<ruby>合<rt>あ</rt></ruby>う<ruby>喜<rt>よろこ</rt></ruby>びも <ruby>手放<rt>てばな</rt></ruby>した<ruby>悲<rt>かな</rt></ruby>しみも", "en": "Both the joy of hands touching and the sorrow of letting go", "tokens": [ { "surface": "手", "lemma": "手", "reading": "て", "pos": "NOUN", "jlpt": "N5", "gloss": "hand" }, { "surface": "触れ合う", "lemma": "触れ合う", "reading": "ふれあう", "pos": "VERB", "jlpt": "N2", "gloss": "to touch each other; come into contact" }, { "surface": "喜び", "lemma": "喜び", "reading": "よろこび", "pos": "NOUN", "jlpt": "N3", "gloss": "joy" }, { "surface": "手放した", "lemma": "手放す", "reading": "てばなした", "pos": "VERB", "jlpt": "N1", "gloss": "to let go of; release" }, { "surface": "悲しみ", "lemma": "悲しみ", "reading": "かなしみ", "pos": "NOUN", "jlpt": "N3", "gloss": "sorrow; sadness" } ] },
    { "jp": "<ruby>飽<rt>あ</rt></ruby>き<ruby>足<rt>た</rt></ruby>らず<ruby>描<rt>えが</rt></ruby>いていく <ruby>地球儀<rt>ちきゅうぎ</rt></ruby>を<ruby>回<rt>まわ</rt></ruby>すように", "en": "Never satisfied, I keep on drawing, as if spinning a globe", "grammar": ["te-iru"], "tokens": [ { "surface": "飽き足らず", "lemma": "飽き足る", "reading": "あきたらず", "pos": "VERB", "jlpt": "N1", "gloss": "to be unsatisfied (negative of 飽き足る)" }, { "surface": "描いて", "lemma": "描く", "reading": "えがいて", "pos": "VERB", "jlpt": "N2", "gloss": "to draw; depict" }, { "surface": "地球儀", "lemma": "地球儀", "reading": "ちきゅうぎ", "pos": "NOUN", "jlpt": "N1", "gloss": "globe (model of the earth)" }, { "surface": "回す", "lemma": "回す", "reading": "まわす", "pos": "VERB", "jlpt": "N3", "gloss": "to spin; turn" } ] }
