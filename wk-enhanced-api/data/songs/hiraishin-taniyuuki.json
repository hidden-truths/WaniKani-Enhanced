    { "jp": "あまりもんの<ruby>愛<rt>あい</rt></ruby>してる", "en": "A leftover \"I love you\"", "grammar": ["te-iru"], "tokens": [ { "surface": "あまりもん", "lemma": "余り物", "reading": "あまりもん", "pos": "NOUN", "jlpt": "N1", "gloss": "leftovers; surplus" }, { "surface": "愛してる", "lemma": "愛する", "reading": "あいしてる", "pos": "VERB", "jlpt": "N3", "gloss": "to love" } ] },
    { "jp": "もう　<ruby>会<rt>あ</rt></ruby>いたい<ruby>愛<rt>あい</rt></ruby>が<ruby>痛<rt>いた</rt></ruby>い<ruby>曖昧<rt>あいまい</rt></ruby>な", "en": "Enough — I want to see you, love hurts, it's all so vague", "grammar": ["tai"], "tokens": [ { "surface": "会いたい", "lemma": "会う", "reading": "あいたい", "pos": "VERB", "jlpt": "N5", "gloss": "to meet; see" }, { "surface": "愛", "lemma": "愛", "reading": "あい", "pos": "NOUN", "jlpt": "N3", "gloss": "love" }, { "surface": "痛い", "lemma": "痛い", "reading": "いたい", "pos": "ADJ", "jlpt": "N5", "gloss": "painful; it hurts" }, { "surface": "曖昧", "lemma": "曖昧", "reading": "あいまい", "pos": "ADJ", "jlpt": "N1", "gloss": "vague; ambiguous" } ] },
