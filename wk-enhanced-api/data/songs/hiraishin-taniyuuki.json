    { "section": "Outro", "jp": "<ruby>全<rt>すべ</rt></ruby>てこの<ruby>歌<rt>うた</rt></ruby>へ<ruby>集<rt>あつ</rt></ruby>めよう", "en": "Let me gather it all into this song", "grammar": ["volitional"], "tokens": [ { "surface": "全て", "lemma": "全て", "reading": "すべて", "pos": "NOUN", "jlpt": "N3", "gloss": "all; everything" }, { "surface": "歌", "lemma": "歌", "reading": "うた", "pos": "NOUN", "jlpt": "N5", "gloss": "song" }, { "surface": "集めよう", "lemma": "集める", "reading": "あつめよう", "pos": "VERB", "jlpt": "N4", "gloss": "to gather; collect" } ] },
