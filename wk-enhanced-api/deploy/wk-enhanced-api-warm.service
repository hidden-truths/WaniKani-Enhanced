# Monthly bulk-warm trigger. Fires `POST /v1/admin/warm {"scope":"all"}`
# against the local server, which returns 202 immediately and runs the
# actual warm in the background. After `dc2629c` (warm-all 409
# concurrency guard) a second trigger while one's already running returns
# 409 — curl --fail-with-body will surface that as a unit failure.
#
# Install at: /etc/systemd/system/wk-enhanced-api-warm.service
# Paired with: wk-enhanced-api-warm.timer (the schedule).
# Manual run:  systemctl start wk-enhanced-api-warm
#
# Reads ADMIN_TOKEN from the same env file as the main service. Unchanged
# by the Docker switch — the container publishes port 3000 to 127.0.0.1
# so curl from the host reaches the API at the same address either way.

[Unit]
Description=Monthly bulk warm of wk-enhanced-api against ImmersionKit
Documentation=https://github.com/<your-user-or-org>/WaniKani/blob/main/wk-enhanced-api/README.md
Requires=wk-enhanced-api.service
After=wk-enhanced-api.service

[Service]
Type=oneshot
EnvironmentFile=/etc/wk-enhanced-api/env

# -f: fail on HTTP >= 400 (treats e.g. expired ADMIN_TOKEN as a unit failure
#     so we get an alert via journalctl/`systemctl list-units --failed`).
# -sS: quiet, but show errors.
# --max-time 30: the endpoint returns 202 in milliseconds; if it's hung past
#                30s something is wrong with the service itself.
ExecStart=/usr/bin/curl -fsS --max-time 30 \
    -X POST http://127.0.0.1:3000/v1/admin/warm \
    -H "Authorization: Bearer ${ADMIN_TOKEN}" \
    -H "Content-Type: application/json" \
    -d '{"scope":"all"}'
