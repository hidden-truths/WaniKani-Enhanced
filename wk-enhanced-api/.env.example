# Copy to .env and adjust. Loaded automatically by Bun.

# HTTP
PORT=3000

# Storage: "local" writes media to LOCAL_MEDIA_DIR and serves it via the
# /media/* route. "s3" uploads to an S3-compatible bucket (DO Spaces / MinIO / AWS).
STORAGE_DRIVER=local
LOCAL_MEDIA_DIR=./dev-data/media

# Public URL prefix that the userscript will hit for media. In local dev this
# is the same host as the API; in prod it's the Spaces CDN endpoint.
MEDIA_PUBLIC_BASE=http://localhost:3000/media

# SQLite database file. Created on first boot if it doesn't exist.
DATABASE_FILE=./dev-data/wk-enhanced-api.sqlite

# Admin bearer token. POST /v1/admin/warm requires Authorization: Bearer <this>.
ADMIN_TOKEN=dev-admin-token

# Optional. Personal WaniKani API v2 token. Required only to enumerate the full
# vocab corpus for the monthly warm. Lazy warming (single-word on demand) works
# without it. Get one at https://www.wanikani.com/settings/personal_access_tokens.
WK_API_TOKEN=

# Refresh thresholds (in days). Entries fresher than this are skipped by the
# warmer unless force=true is passed.
WARM_REFRESH_DAYS=30
INDEX_META_REFRESH_DAYS=7

# S3-compatible storage. Only consulted when STORAGE_DRIVER=s3.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Set to true for MinIO / DO Spaces (uses path-style URLs); false for AWS S3.
S3_FORCE_PATH_STYLE=true
