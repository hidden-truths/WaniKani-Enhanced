# Copy to .env and adjust. Loaded automatically by Bun.

# HTTP
PORT=3000

# Storage: "local" writes media to LOCAL_MEDIA_DIR and serves it via the
# /media/* route. "s3" uploads to an S3-compatible bucket (DO Spaces / MinIO / AWS).
STORAGE_DRIVER=local
LOCAL_MEDIA_DIR=./dev-data/media

# Public URL prefix that the userscript will hit for media. In local dev this
# is the same host as the API; in prod it's the Spaces CDN endpoint.
MEDIA_PUBLIC_BASE=http://localhost:3000/media

# SQLite database file. Created on first boot if it doesn't exist.
DATABASE_FILE=./dev-data/wk-enhanced-api.sqlite

# Admin bearer token. POST /v1/admin/warm requires Authorization: Bearer <this>.
ADMIN_TOKEN=dev-admin-token

# Optional. Personal WaniKani API v2 token. Required only to enumerate the full
# vocab corpus for the monthly warm. Lazy warming (single-word on demand) works
# without it. Get one at https://www.wanikani.com/settings/personal_access_tokens.
WK_API_TOKEN=

# Refresh thresholds (in days). Entries fresher than this are skipped by the
# warmer unless force=true is passed.
WARM_REFRESH_DAYS=30
INDEX_META_REFRESH_DAYS=7

# --- Accounts / study app ---------------------------------------------------
# The verb-trainer app served at / lets users register and sync progress.
# How long a login session lasts before re-auth is required.
SESSION_TTL_DAYS=30
# Whether the session cookie carries the Secure flag. Keep FALSE in local dev
# (http://localhost — a Secure cookie would be silently dropped and login would
# appear to not stick). Set TRUE in prod where Cloudflare terminates HTTPS.
COOKIE_SECURE=false
# Session-cookie Domain. BLANK = host-only (correct for dev + same-origin deploys).
# In the two-container prod topology — study app at wkenhanced.dev, this API at
# api.wkenhanced.dev — set COOKIE_DOMAIN=.wkenhanced.dev so the cookie spans both.
COOKIE_DOMAIN=
# Cross-origin allowlist for the study-app routes (/v1/auth, /v1/progress, /v1/sessions,
# /v1/minna). These origins may send CREDENTIALED (cookie) requests; cross-origin +
# credentials means the server echoes the exact origin (never '*'). Defaults to the Vite
# dev server, so local `bun dev` + `vite dev` (study-app) work cross-origin out of the box.
# In prod set to the study-app origin: https://wkenhanced.dev. Comma-separated.
STUDY_APP_ORIGINS=http://localhost:5173
# Comma-separated allowlist of account emails allowed to open the みんなの日本語
# dashboard + native audio (/v1/minna/*). Blank = any signed-in user. Set to your
# own email in prod to keep the copyrighted Minna no Nihongo content private.
MINNA_OWNER_EMAILS=

# --- 歌 / Songs tab — lyrics analysis -----------------------------------------
# The Songs tab's POST /v1/songs/analyze turns pasted lyrics into furigana +
# English + grammar + per-word JLPT by calling Claude. OPTIONAL: blank = the
# analyze endpoint returns 503 (analysis_unavailable) and the rest of Songs
# (library, reading existing songs, mining) keeps working. Provision the key to
# light up the Add flow — like the Siri-voice rollout.
ANTHROPIC_API_KEY=
# Model for the analysis pass. Defaults to Opus 4.8 (best furigana accuracy);
# set to a cheaper model (e.g. claude-sonnet-4-6) to trade accuracy for cost.
ANTHROPIC_MODEL=claude-opus-4-8

# S3-compatible storage. Only consulted when STORAGE_DRIVER=s3.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Set to true for MinIO / DO Spaces (uses path-style URLs); false for AWS S3.
S3_FORCE_PATH_STYLE=true
